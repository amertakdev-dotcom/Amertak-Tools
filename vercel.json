{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/css/*.css",
      "use": "@vercel/static"
    },
    {
      "src": "**/js/*.js",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/view/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    }
  ]
}
