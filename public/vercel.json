{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/share/:id", "destination": "/share.html" },
    { "source": "/about", "destination": "/about/index.html" },
    { "source": "/tools/cloude", "destination": "/tools/cloude/index.html" },
    { "source": "/tools/cloude/share/:id", "destination": "/tools/cloude/share/[id].html" },
    { "source": "/tools/file-converter", "destination": "/tools/file-converter/index.html" },
    { "source": "/tools/:tool", "destination": "/tools/:tool/index.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/register", "destination": "/register.html" }
  ],
  "redirects": [
    { "source": "/tools/image-to-url", "destination": "/tools/cloude/", "statusCode": 301 },
    { "source": "/tools/cloude", "destination": "/tools/cloude/", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain" }]
    },
    {
      "source": "/sitemap.xml",
      "headers": [{ "key": "Content-Type", "value": "application/xml" }]
    },
    {
      "source": "/assets/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/:path*",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }]
    }
  ]
}
