# Server
PORT=3001
NODE_ENV=production

# Auth
JWT_SECRET=replace_with_a_long_random_string
CORS_ORIGIN=https://amertak-tools.vercel.app,https://www.amertak-tools.vercel.app

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Frontend Google OAuth (for Vercel deployment)
PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# MongoDB
MONGOURL=mongodb+srv://username:password@cluster.mongodb.net/?appName=toolsAmertak

# Optional tool settings
OPENAI_API_KEY=sk-your-api-key-here
YTDLP_PATH=yt-dlp
